# LLM Configuration
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=google/gemini-2.5-flash
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY
EMBEDDING_MODEL_TYPE=openrouter
EMBEDDING_MODEL_NAME=google/gemini-embedding-001

# RAG Configuration
RAG_MAX_RETRIEVED_DOCS=10
RAG_WITH_CHUNKING=true
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=128

# Graph API Configuration
GRAPH_API_BASE_URL=http://langgraph-api:8000
INGESTION_GRAPH_ID=ingestion-agent
EMAIL_GRAPH_ID=email-ingestion-agent
RAG_GRAPH_ID=RAG-agent

# Graph Monitoring
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
LANGSMITH_API_KEY="YOUR_LANGSMITH_API_KEY"
LANGSMITH_PROJECT="success-stories-knowledge-base"

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@langgraph-postgres:5432/postgres
POSTGRES_HOST=langgraph-postgres
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# MinIO Configuration
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=iac-agent

# Weaviate Configuration
WEAVIATE_HTTP_HOST=weaviate
WEAVIATE_HTTP_PORT=8080
WEAVIATE_GRPC_HOST=weaviate
WEAVIATE_GRPC_PORT=50051
WEAVIATE_API_KEYS=my-api-key
WEAVIATE_INDEX_NAME=SuccessStories_Framework
WEAVIATE_TEXT_KEY=text
INGESTION_BATCH_SIZE=1000
INGESTION_OVERWRITE=false

# Email Configuration
CLIENT_ID="your-azure-client-id"
CLIENT_SECRET="your-azure-client-secret"
TENANT_ID="your-azure-tenant-id"
MAIL_USER=your-email@example.com
POLLING_INTERVAL_SECONDS=3600
MAX_EMAILS_PER_POLL=50

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
ADMIN_PASSWORD=your default admin password here (initial user)

# Logging
LOG_LEVEL=INFO